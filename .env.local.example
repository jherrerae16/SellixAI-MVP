# =============================================================
# Sellix AI — Plantilla de Variables de Entorno
# NUNCA versionar .env.local — copiar este archivo y completar
# =============================================================

# NextAuth.js — obligatorio en producción
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET=

# URL pública del sitio (sin slash final)
# Desarrollo: http://localhost:3000
# Producción: https://tu-proyecto.vercel.app
NEXTAUTH_URL=http://localhost:3000

# Credenciales del único usuario del dashboard
APP_USER=admin

# Contraseña del usuario del dashboard
APP_PASSWORD=tu_contraseña_segura

# =============================================================
# Motor de Campañas — Email (Resend) + WhatsApp (Twilio)
# =============================================================

# Resend — API key para envío de emails
# Crear cuenta gratis en https://resend.com (100 emails/día)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=Sellix AI <onboarding@resend.dev>

# Twilio — WhatsApp Sandbox
# Crear cuenta en https://twilio.com → Messaging → WhatsApp Sandbox
# El teléfono receptor debe unirse al sandbox primero: enviar "join <palabra>" al +14155238886
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Demo: TODOS los mensajes se envían a estos destinos (no al cliente real)
DEMO_EMAIL=tu-email@gmail.com
DEMO_PHONE=whatsapp:+573001234567

# =============================================================
# Copiloto IA (Anthropic Claude API)
# =============================================================

# API key de Google Gemini para el copiloto inteligente (GRATIS)
# Crear en https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Tasa de comisión para atribución (0.05 = 5%)
COMMISSION_RATE=0.05

# =============================================================
# Postgres (Neon) — source of truth multi-tenant
# =============================================================

# Crear proyecto en https://neon.tech (free tier)
# Formato: postgresql://USER:PASS@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://USER:PASS@HOST/DB?sslmode=require

# Tenant default usado durante el piloto single-tenant
DEFAULT_TENANT_ID=superofertas
